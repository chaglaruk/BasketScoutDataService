# BasketScoutDataService — Ortam Değişkenleri Şablonu
# Gerçek değerleri .env dosyasına kopyalayın (git'e eklemeyin!)
# cp .env.example .env

# ── Sunucu ───────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8787
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# ── Veritabanı ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/basketscout.db

# ── Cache / TTL (saniye cinsinden) ───────────────────────────
PRICE_TTL_SECONDS=21600
AVAILABILITY_TTL_SECONDS=3600

# ── Admin ────────────────────────────────────────────────────
# Opsiyonel: admin endpoint'lerini korumak için basit token (X-Admin-Token header)
# Ayarlanmazsa admin endpoint'leri korumasız kalır (lokal/dev kullanımı için).
# ADMIN_TOKEN=your-super-secret-admin-token-here

# ── Provider ayarları ────────────────────────────────────────
DEFAULT_PROVIDER=mock
ENABLE_SCRAPING=false
SCRAPING_RATE_LIMIT_SECONDS=2.0

# ── Open Food Facts ──────────────────────────────────────────
OFF_USER_AGENT=BasketScoutDataService/0.1.0 (contact@example.com)

# ── Loglama ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
