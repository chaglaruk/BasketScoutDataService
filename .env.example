# BasketScoutDataService - Environment template
# Copy to .env for local use. Do not commit secrets.

# ----- Runtime / Server -----
# Deployment aliases supported: HOST/PORT/ENV
HOST=127.0.0.1
PORT=8787
ENV=development
APP_VERSION=0.1.0
DEBUG=true

# Optional legacy aliases (still supported)
# APP_HOST=127.0.0.1
# APP_PORT=8787
# APP_ENV=development

# ----- Database -----
# Prefer DATABASE_URL for production.
# Example (SQLite): DATABASE_URL=sqlite:///./data/basketscout.db
# Example (PostgreSQL): DATABASE_URL=postgresql+psycopg://user:pass@dbhost:5432/basketscout
DATABASE_URL=sqlite:///./data/basketscout.db

# If DATABASE_URL is omitted, SQLITE_PATH is used.
SQLITE_PATH=./data/basketscout.db

# ----- Cache / TTL (seconds) -----
PRICE_TTL_SECONDS=21600
AVAILABILITY_TTL_SECONDS=3600

# ----- Admin Security -----
# Required before public deployment.
# ADMIN_TOKEN=<set-a-strong-random-token>
REQUIRE_ADMIN_TOKEN_IN_PRODUCTION=true

# ----- CORS -----
# Comma-separated origin list, no wildcard by default.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# ----- Provider Settings -----
DEFAULT_PROVIDER=mock
ENABLE_SCRAPING=false
SCRAPING_RATE_LIMIT_SECONDS=2.0
WEB_OBSERVATION_ENABLED=true
WEB_OBSERVATION_TIMEOUT_SECONDS=12
WEB_OBSERVATION_USER_AGENT=BasketScoutDataService-WebObservation/0.1.0 (public-page-safe; contact@example.com)

# ----- Open Food Facts -----
OFF_USER_AGENT=BasketScoutDataService/0.1.0 (contact@example.com)

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=json
